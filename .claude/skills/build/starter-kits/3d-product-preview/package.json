{
  "name": "starterkit-3d-product-preview",
  "version": "1.0.0",
  "description": "CE.SDK 3D Product Configurator Starterkit",
  "private": true,
  "scripts": {
    "secrets": "bash scripts/setup-secrets.sh",
    "dev": "cesdk-js-dev vite",
    "prebuild": "npm run check:all",
    "build": "vite build",
    "preview": "vite preview",
    "check:syntax": "tsc --project tsconfig.json --noEmit",
    "check:format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,html}\"",
    "check:lint": "eslint \"**/*.{ts,tsx,js,jsx}\"",
    "check:all": "npm run check:syntax && npm run check:format && npm run check:lint",
    "fix:format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,html}\"",
    "fix:lint": "eslint --fix \"**/*.{ts,tsx,js,jsx}\"",
    "fix:all": "npm run fix:format && npm run fix:lint",
    "test:unit": "exit 0",
    "test:integration": "exit 0",
    "test:component": "exit 0",
    "test:e2e": "exit 0",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:component && npm run test:e2e",
    "qa": "npm run build && npm run test:all",
    "ci": "npm run check:all && npm run qa",
    "capture:hero_image": "node scripts/capture-hero.mjs"
  },
  "dependencies": {
    "@cesdk/cesdk-js": "workspace:*",
    "@cesdk/engine": "workspace:*",
    "@google/model-viewer": "^4.0.0",
    "classnames": "^2.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-jsdoc": "^46.0.0",
    "playwright": "^1.55.1",
    "prettier": "^3.0.0",
    "sharp": "^0.34.4",
    "typescript": "^5.0.0",
    "vite": "^6.0.3",
    "@types/node": "^20.0.0"
  }
}
