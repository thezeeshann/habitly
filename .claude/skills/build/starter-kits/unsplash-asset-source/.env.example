# CE.SDK License Key
# Option 1: Run `npm run secrets` to retrieve from 1Password (requires 1Password CLI)
# Option 2: Get your free trial license at https://img.ly/forms/free-trial
VITE_CESDK_LICENSE=YOUR_LICENSE_KEY_HERE

# Unsplash API Proxy URL
# IMPORTANT: Never expose your Unsplash API key in frontend code.
# Set up a proxy server that adds the API key server-side.
# See: https://github.com/unsplash/unsplash-js#creating-an-instance
# Default uses IMG.LY's demo proxy (for development only)
VITE_UNSPLASH_API_URL=VITE_UNSPLASH_API_URL_HERE
