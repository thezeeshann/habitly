# Environment variables
.env.local
.env

# Build output
dist/
node_modules/

# Lock files (use npm ci in CI)
yarn.lock
tsconfig.tsbuildinfo

# Auto-generated TypeScript config for local development
tsconfig.local.json

# Release directory - ignore all generated files, keep only template config
# During CI build, files are copied from main src/ and public/ into release/
release/*
# Whitelist template configuration files
!release/package.json
!release/tsconfig.json
!release/vite.config.ts
# Whitelist src directory but ignore its contents except entry point
!release/src/
release/src/*
!release/src/index.tsx
