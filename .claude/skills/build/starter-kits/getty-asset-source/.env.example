# CE.SDK License Key
# Option 1: Run `npm run secrets` to retrieve from 1Password (requires 1Password CLI)
# Option 2: Get your free trial license at https://img.ly/forms/free-trial
VITE_CESDK_LICENSE=YOUR_LICENSE_KEY_HERE

# Getty Images API Proxy URL
# Set up a proxy server to handle Getty Images API authentication
# The proxy should accept query, page, perPage parameters and return CE.SDK formatted results
VITE_GETTY_IMAGES_PROXY_URL=VITE_GETTY_IMAGES_PROXY_URL_HERE
