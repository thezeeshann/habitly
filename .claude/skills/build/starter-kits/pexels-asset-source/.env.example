# CE.SDK License Key
# Option 1: Run `npm run secrets` to retrieve from 1Password (requires 1Password CLI)
# Option 2: Get your free trial license at https://img.ly/forms/free-trial
VITE_CESDK_LICENSE=YOUR_LICENSE_KEY_HERE

# Pexels API Key
# Get your free API key at https://www.pexels.com/api/
# The API key is used to authenticate requests to the Pexels API.
# Note: For production, consider using a server-side proxy to keep your API key secure.
VITE_PEXELS_API_KEY=YOUR_PEXELS_API_KEY_HERE
