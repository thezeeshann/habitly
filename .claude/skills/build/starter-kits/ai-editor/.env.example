# ==============================================================================
# AI Gateway Configuration
# ==============================================================================
#
# The starterkit talks to the IMG.LY AI Gateway — a single endpoint that
# brokers requests to every supported model (fal.ai, OpenAI, Anthropic,
# ElevenLabs, …). You only need one credential.
#
# Create an API key in the IMG.LY dashboard:
#   https://img.ly/dashboard
#
# Paste it below. The starterkit returns the key to the gateway via
# `{ dangerouslyExposeApiKey }` — this is fine for local development,
# but DO NOT ship a production build with a raw key baked in. Replace
# the dev key with a short-lived token from your backend when deploying.
# ==============================================================================

# API key from https://img.ly/dashboard. Leave empty when the starterkit
# is embedded in the IMG.LY showcases demo — the hosting page will
# provide a session token via postMessage instead.
VITE_AI_API_KEY=

# Optional — override the gateway URL. Defaults to https://gateway.img.ly.
# VITE_AI_GATEWAY_URL=
