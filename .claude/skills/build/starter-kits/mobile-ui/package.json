{
  "name": "starterkit-mobile-ui",
  "version": "1.0.0",
  "description": "CE.SDK Mobile UI Starterkit - A mobile-optimized editing interface built with React",
  "private": true,
  "scripts": {
    "secrets": "bash scripts/setup-secrets.sh",
    "dev": "cesdk-js-dev vite",
    "prebuild": "npm run check:all",
    "build": "vite build",
    "preview": "vite preview",
    "check:syntax": "tsc --project tsconfig.json --noEmit",
    "check:format": "prettier --check \"**/*.{ts,tsx,js,json,html,css}\"",
    "check:lint": "eslint \"**/*.{ts,tsx,js}\"",
    "check:all": "npm run check:syntax && npm run check:format && npm run check:lint",
    "fix:format": "prettier --write \"**/*.{ts,tsx,js,json,html,css}\"",
    "fix:lint": "eslint --fix \"**/*.{ts,tsx,js}\"",
    "fix:all": "npm run fix:format && npm run fix:lint",
    "test:unit": "exit 0",
    "test:integration": "exit 0",
    "test:component": "exit 0",
    "test:e2e": "exit 0",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:component && npm run test:e2e",
    "qa": "npm run build && npm run test:all",
    "ci": "npm run check:all && npm run qa",
    "capture:hero_image": "node scripts/capture-hero.mjs"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@cesdk/cesdk-js": "workspace:*",
    "@cesdk/engine": "workspace:*",
    "classnames": "^2.3.2",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "react-masonry-css": "^1.0.16",
    "react-slider": "^2.0.6"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/react-slider": "^1.3.6",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.50.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-jsdoc": "^46.0.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "playwright": "^1.55.1",
    "prettier": "^3.0.0",
    "sharp": "^0.34.4",
    "typescript": "^5.0.0",
    "vite": "^6.0.3",
    "vite-plugin-svgr": "^4.2.0",
    "@types/node": "^20.0.0"
  }
}
